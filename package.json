{
  "name": "tend",
  "version": "0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "nuxt build && vitest run --config vitest.e2e.config.ts",
    "test:e2e:server": "NUXT_PUBLIC_BACKEND_MODE=server nuxt build && vitest run --config vitest.e2e-server.config.ts",
    "test:e2e:pwa": "nuxt generate && vitest run --config vitest.e2e.config.ts test/e2e/pwa.spec.ts",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "seed": "tsx scripts/write-seed-data.ts"
  },
  "dependencies": {
    "@nuxt/a11y": "^1.0.0-alpha.1",
    "@nuxt/eslint": "^1.13.0",
    "@nuxt/fonts": "^0.13.0",
    "@nuxt/hints": "^1.0.0-alpha.6",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@pinia/nuxt": "^0.11.3",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "eslint": "^9.39.2",
    "idb-keyval": "^6.2.2",
    "nuxt": "^4.3.0",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-icons": "^4.0.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "ssstyles": "^1.3.6",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.1",
    "@vitest/browser-playwright": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  }
}
